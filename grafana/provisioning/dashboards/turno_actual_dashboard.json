          "datasource": {
            "type": "mssql",
            "uid": "mes_sqlserver"
          },
          "format": "table",
          "rawSql": "SELECT CAST(SUM(CASE WHEN state = 'Running' THEN DATEDIFF(SECOND, timestamp, DATEADD(MINUTE, 15, timestamp)) ELSE 0 END) AS FLOAT) / NULLIF(SUM(CASE WHEN state = 'Stopped' THEN 1 ELSE 0 END), 0) AS [MTBF] FROM mes_machine_events WHERE machine_id = 'MAQ-01' AND timestamp >= CAST(CAST(GETDATE() AS DATE) AS DATETIME)",
          "refId": "A"
        }
      ],
      "title": "MTBF (Tiempo Medio Entre Fallos)",
      "type": "stat"
