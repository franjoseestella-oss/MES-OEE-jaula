                                       "content":  "\u003cstyle\u003e\n.turno-container{display:flex;flex-direction:column;height:100%;width:100%;font-family:\u0027Outfit\u0027,\u0027Inter\u0027,-apple-system,sans-serif;color:#f3f4f6;padding:16px;box-sizing:border-box;background:transparent;justify-content:space-between}.turno-header{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(255,255,255,0.08);padding-bottom:8px;margin-bottom:12px}.turno-title{font-size:18px;font-weight:800;color:#fff;letter-spacing:0.5px}.turno-times{font-size:13px;font-weight:600;color:#9ca3af;background:rgba(255,255,255,0.05);padding:4px 10px;border-radius:4px}.turno-content{display:flex;flex-direction:column;flex-grow:1;justify-content:space-between;gap:12px}.pieces-row{display:flex;gap:12px}.piece-card{flex:1;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.04);border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;justify-content:center}.card-target{border-left:3px solid #00f2fe}.card-ok{border-left:3px solid #2fd06a}.card-nok{border-left:3px solid #e32636}.piece-label{font-size:10px;font-weight:700;color:#9ca3af;letter-spacing:0.5px;margin-bottom:4px}.piece-value{font-size:22px;font-weight:800;color:#fff}.card-target .piece-value{color:#00f2fe;text-shadow:0 0 10px rgba(0,242,254,0.2)}.card-ok .piece-value{color:#2fd06a;text-shadow:0 0 10px rgba(47,208,106,0.2)}.card-nok .piece-value{color:#e32636;text-shadow:0 0 10px rgba(227,38,54,0.2)}.durations-section{display:flex;flex-direction:column;gap:12px}.dur-group{display:flex;flex-direction:column;gap:4px}.dur-header{display:flex;justify-content:space-between;font-size:11px;font-weight:700;letter-spacing:0.5px;color:#d1d5db}.dur-value{color:#9ca3af;font-weight:600}.dur-bg{height:8px;background:rgba(255,255,255,0.05);border-radius:4px;overflow:hidden}.dur-bar{height:100%;border-radius:4px;width:0%;transition:width 0.8s ease-in-out}.bar-marcha{background:linear-gradient(90deg,#11998e,#38ef7d)}.bar-parada{background:linear-gradient(90deg,#2b5876,#4e4376)}.bar-error{background:linear-gradient(90deg,#f857a6,#ff5858)}\n\u003c/style\u003e\n\u003cdiv class=\"turno-container\"\u003e\u003cdiv class=\"turno-header\"\u003e\u003cspan class=\"turno-title\"\u003eTurno \u003cspan id=\"shift-label\"\u003eT1\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"turno-times\" id=\"shift-times\"\u003eInicio: 07:00 | Fin: 15:00\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"turno-content\"\u003e\u003cdiv class=\"pieces-row\"\u003e\u003cdiv class=\"piece-card card-target\"\u003e\u003cspan class=\"piece-label\"\u003ePLANIFICADAS (TEÓRICO)\u003c/span\u003e\u003cspan class=\"piece-value\" id=\"target-val\"\u003e0\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"piece-card card-ok\"\u003e\u003cspan class=\"piece-label\"\u003eSECUENCIAS OK\u003c/span\u003e\u003cspan class=\"piece-value\" id=\"ok-val\"\u003e0\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"piece-card card-nok\"\u003e\u003cspan class=\"piece-label\"\u003eSECUENCIAS NOK\u003c/span\u003e\u003cspan class=\"piece-value\" id=\"nok-val\"\u003e0\u003c/span\u003e\u003c/div\u003e\u003c/div\u003e\u003cdiv class=\"durations-section\"\u003e\u003cdiv class=\"dur-group\"\u003e\u003cdiv class=\"dur-header\"\u003e\u003cspan\u003eTIEMPO EN MARCHA\u003c/span\u003e\u003cspan class=\"dur-value\" id=\"marcha-val\"\u003e0h 00m (0%)\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"dur-bg\"\u003e\u003cdiv class=\"dur-bar bar-marcha\" id=\"marcha-bar\" style=\"width:0%\"\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003cdiv class=\"dur-group\"\u003e\u003cdiv class=\"dur-header\"\u003e\u003cspan\u003eTIEMPO PARADA\u003c/span\u003e\u003cspan class=\"dur-value\" id=\"parada-val\"\u003e0h 00m (0%)\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"dur-bg\"\u003e\u003cdiv class=\"dur-bar bar-parada\" id=\"parada-bar\" style=\"width:0%\"\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003cdiv class=\"dur-group\"\u003e\u003cdiv class=\"dur-header\"\u003e\u003cspan\u003eTIEMPO ERROR\u003c/span\u003e\u003cspan class=\"dur-value\" id=\"error-val\"\u003e0h 00m (0%)\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"dur-bg\"\u003e\u003cdiv class=\"dur-bar bar-error\" id=\"error-bar\" style=\"width:0%\"\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\n\u003cscript\u003e\n(function(){var API=window.location.origin+\u0027/api\u0027;var tV=document.getElementById(\u0027target-val\u0027);var oV=document.getElementById(\u0027ok-val\u0027);var nV=document.getElementById(\u0027nok-val\u0027);var mV=document.getElementById(\u0027marcha-val\u0027);var mB=document.getElementById(\u0027marcha-bar\u0027);var pV=document.getElementById(\u0027parada-val\u0027);var pB=document.getElementById(\u0027parada-bar\u0027);var eV=document.getElementById(\u0027error-val\u0027);var eB=document.getElementById(\u0027error-bar\u0027);function fmt(s){var h=Math.floor(s/3600);var m=Math.floor((s%3600)/60);return h+\u0027h \u0027+(m\u003c10?\u00270\u0027:\u0027\u0027)+m+\u0027m\u0027;}function upd(){var x=new XMLHttpRequest();x.open(\u0027POST\u0027,API+\u0027/ds/query\u0027,true);x.setRequestHeader(\u0027Content-Type\u0027,\u0027application/json\u0027);x.onload=function(){if(x.status!==200)return;try{var d=JSON.parse(x.responseText);var f=d.results\u0026\u0026d.results.A\u0026\u0026d.results.A.frames;if(f\u0026\u0026f.length\u003e0){var fld=f[0].schema.fields;var v=f[0].data.values;var r={};for(var i=0;i\u003cfld.length;i++)r[fld[i].name]=v[i][0];if(tV)tV.textContent=r.planificadas||0;if(oV)oV.textContent=r.good_pieces||0;if(nV)nV.textContent=r.bad_pieces||0;var run=r.duration_running||0;var stp=r.duration_stopped||0;var err=r.duration_error||0;var tot=run+stp+err;if(tot===0)tot=28800;var rP=Math.round(run/tot*100);var sP=Math.round(stp/tot*100);var eP=Math.round(err/tot*100);if(mV\u0026\u0026mB){mV.textContent=fmt(run)+\u0027 (\u0027+rP+\u0027%)\u0027;mB.style.width=rP+\u0027%\u0027;}if(pV\u0026\u0026pB){pV.textContent=fmt(stp)+\u0027 (\u0027+sP+\u0027%)\u0027;pB.style.width=sP+\u0027%\u0027;}if(eV\u0026\u0026eB){eV.textContent=fmt(err)+\u0027 (\u0027+eP+\u0027%)\u0027;eB.style.width=eP+\u0027%\u0027;}}}catch(e){console.error(e);}};x.send(JSON.stringify({queries:[{datasource:{type:\u0027mssql\u0027,uid:\u0027mes_sqlserver\u0027},rawSql:\"DECLARE @SD DATE=CAST(CAST(GETDATE() AS datetime2) AT TIME ZONE \u0027UTC\u0027 AT TIME ZONE \u0027Romance Standard Time\u0027 AS DATE);DECLARE @UO INT=DATEDIFF(hour,GETUTCDATE(),GETDATE());DECLARE @SS DATETIME=DATEADD(hour,7-@UO,CAST(@SD AS DATETIME));DECLARE @SE DATETIME=DATEADD(hour,15-@UO,CAST(@SD AS DATETIME));IF OBJECT_ID(\u0027tempdb..#CS\u0027) IS NOT NULL DROP TABLE #CS;CREATE TABLE #CS(gi INT IDENTITY(1,1) PRIMARY KEY,f DATE);WITH CB AS(SELECT Fecha,Laborable,Cant_A_Fabricar,SUM(CASE WHEN Cant_A_Fabricar=18.5 THEN 1 ELSE 0 END) OVER(ORDER BY Fecha ASC) AS C185 FROM dbo.CALENDARIO_LABORAL WHERE Fecha\u003e=\u00272026-06-24\u0027) INSERT INTO #CS(f) SELECT cb.Fecha FROM CB cb CROSS APPLY(SELECT ROW_NUMBER() OVER(ORDER BY id) AS si FROM dbo.HHSS_18 WHERE cb.Cant_A_Fabricar=18.0 OR cb.Cant_A_Fabricar IS NULL OR(cb.Cant_A_Fabricar NOT IN(19.0,18.5) AND cb.Cant_A_Fabricar\u003e0) UNION ALL SELECT ROW_NUMBER() OVER(ORDER BY id) FROM dbo.HHSS_19 WHERE cb.Cant_A_Fabricar=19.0 UNION ALL SELECT ROW_NUMBER() OVER(ORDER BY id) FROM dbo.HHSS_18_5 WHERE cb.Cant_A_Fabricar=18.5 AND cb.C185%2=1 AND id BETWEEN 1 AND 19 UNION ALL SELECT ROW_NUMBER() OVER(ORDER BY id) FROM dbo.HHSS_18_5 WHERE cb.Cant_A_Fabricar=18.5 AND cb.C185%2=0 AND id BETWEEN 20 AND 38) s WHERE cb.Laborable=1 AND cb.Cant_A_Fabricar\u003e0 ORDER BY cb.Fecha ASC,s.si ASC;IF OBJECT_ID(\u0027tempdb..#MS\u0027) IS NOT NULL DROP TABLE #MS;CREATE TABLE #MS(id INT PRIMARY KEY,pd DATE);WITH OE AS(SELECT id,ROW_NUMBER() OVER(ORDER BY TRY_CAST(fecha_montaje AS DATE) ASC,TRY_CAST(secuencia AS INT) ASC) as gi FROM dbo.JAULA_ERP WHERE TRY_CAST(secuencia AS INT)\u003e=227) INSERT INTO #MS(id,pd) SELECT o.id,cs.f FROM OE o INNER JOIN #CS cs ON cs.gi=o.gi;DECLARE @T INT,@OK INT,@NK INT;SELECT @T=COUNT(*) FROM #MS WHERE pd=@SD;SELECT @OK=COUNT(DISTINCT CASE WHEN l.OK_NOK=\u0027OK\u0027 THEN l.NBASTIDOR END),@NK=COUNT(DISTINCT CASE WHEN l.OK_NOK=\u0027NOK\u0027 THEN l.NBASTIDOR END) FROM dbo.LOG_TABLA l INNER JOIN dbo.JAULA_ERP e ON e.bastidor=l.NBASTIDOR WHERE l.FECHA_HORA_FIN_SEC IS NOT NULL AND CAST(CAST(l.FECHA_HORA_FIN_SEC AS datetime2) AT TIME ZONE \u0027UTC\u0027 AT TIME ZONE \u0027Romance Standard Time\u0027 AS DATE)=@SD;WITH ED AS(SELECT state,timestamp,LEAD(timestamp) OVER(ORDER BY timestamp) AS nt FROM dbo.mes_machine_events WHERE machine_id=\u0027JAULA-01\u0027 AND timestamp\u003e=@SS AND timestamp\u003c=@SE),AD AS(SELECT SUM(CASE WHEN state IN(\u0027EN_PROCESO\u0027,\u0027SECUENCIA_INICIADA\u0027) THEN DATEDIFF(second,timestamp,CASE WHEN nt IS NULL OR nt\u003e@SE THEN @SE ELSE nt END) ELSE 0 END) AS dr,SUM(CASE WHEN state IN(\u0027EN_ESPERA\u0027,\u0027Idle\u0027,\u0027FINALIZADA\u0027) THEN DATEDIFF(second,timestamp,CASE WHEN nt IS NULL OR nt\u003e@SE THEN @SE ELSE nt END) ELSE 0 END) AS ds,SUM(CASE WHEN state IN(\u0027Aborting\u0027,\u0027Disconnected\u0027) THEN DATEDIFF(second,timestamp,CASE WHEN nt IS NULL OR nt\u003e@SE THEN @SE ELSE nt END) ELSE 0 END) AS de FROM ED) SELECT COALESCE(@T,0) AS planificadas,COALESCE(@OK,0) AS good_pieces,COALESCE(@NK,0) AS bad_pieces,COALESCE(dr,0) AS duration_running,COALESCE(ds,0) AS duration_stopped,COALESCE(de,0) AS duration_error FROM AD;\",refId:\u0027A\u0027,format:\u0027table\u0027}]}));}upd();setInterval(upd,5000);})();\n\u003c/script\u003e",
