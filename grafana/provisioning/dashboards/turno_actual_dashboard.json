            "targets": [
                {
                    "datasource": {
                        "type": "mssql",
                        "uid": "mes_sqlserver"
                    },
                    "format": "table",
                    "rawSql": "DECLARE @PlotDate DATE = CAST(CAST(GETDATE() AS datetime2) AT TIME ZONE 'UTC' AT TIME ZONE 'Romance Standard Time' AS DATE);\nDECLARE @UTCOffset INT = DATEDIFF(hour, GETUTCDATE(), GETDATE());\nDECLARE @ShiftStartDT DATETIME = DATEADD(hour, 7 - @UTCOffset, CAST(@PlotDate AS DATETIME));\nDECLARE @ShiftEndDT DATETIME = DATEADD(hour, 15 - @UTCOffset, CAST(@PlotDate AS DATETIME));\n\nSELECT \n  timestamp AS time,\n  CASE state\n    WHEN 'EN_ESPERA' THEN 'Esperando máquina'\n    WHEN 'EN_PROCESO' THEN 'Running'\n    WHEN 'SECUENCIA_INICIADA' THEN 'Running'\n    WHEN 'FINALIZADA' THEN 'Tiempo excedido'\n    WHEN 'Idle' THEN 'Tiempo excedido'\n    WHEN 'Aborting' THEN 'Alarma'\n    WHEN 'Disconnected' THEN 'Alarma'\n    ELSE state\n  END AS [Estado]\nFROM mes_machine_events\nWHERE machine_id = 'JAULA-01'\n  AND timestamp >= @ShiftStartDT\n  AND timestamp <= @ShiftEndDT\nORDER BY timestamp",
                    "refId": "A"
                }
            ],
            "title": "Línea de Tiempo de Estados",
            "type": "state-timeline"
        },
        {
