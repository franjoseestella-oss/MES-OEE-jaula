    {
      "id": 10,
      "type": "stat",
      "title": "OEE GLOBAL",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#E32636", "value": null },
              { "color": "#F4A623", "value": 75 },
              { "color": "#2FD06A", "value": 85 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT COALESCE((SELECT TOP 1 oee * 100 FROM mes_oee_snapshots WHERE oee IS NOT NULL ORDER BY ts DESC), 0.0) AS value",
        "format": "table",
        "refId": "A"
