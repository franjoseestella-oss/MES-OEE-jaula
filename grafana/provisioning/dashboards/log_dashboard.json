      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#E32636", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value, GETUTCDATE() AS time FROM LOG_TABLA WHERE OK_NOK <> 'OK' AND fecha_creacion >= DATEADD(day, -30, GETUTCDATE())",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "TASA DE APROBACIÓN (OK %)",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#E32636", "value": null },
              { "color": "#F4A623", "value": 85 },
              { "color": "#2FD06A", "value": 95 }
