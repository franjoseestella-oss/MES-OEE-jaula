{
  "id": null,
  "uid": "mes-log-v1",
  "title": "LOGISNEXT — HISTORIAL DE PRUEBAS (LOG)",
  "description": "Historial de pruebas de la jaula de elevación y tiempos registrados",
  "tags": ["mes", "log", "pruebas"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30d", "to": "now" },
  "graphTooltip": 1,
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PRUEBAS TOTALES (Últimos 30 días)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#25C9D6", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value, GETUTCDATE() AS time FROM LOG_TABLA WHERE fecha_creacion >= DATEADD(day, -30, GETUTCDATE())",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PRUEBAS OK (Últimos 30 días)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#2FD06A", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value, GETUTCDATE() AS time FROM LOG_TABLA WHERE OK_NOK = 'OK' AND fecha_creacion >= DATEADD(day, -30, GETUTCDATE())",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "PRUEBAS NOK (Últimos 30 días)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#E32636", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value, GETUTCDATE() AS time FROM LOG_TABLA WHERE OK_NOK <> 'OK' AND fecha_creacion >= DATEADD(day, -30, GETUTCDATE())",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "TASA DE APROBACIÓN (OK %)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#E32636", "value": null },
              { "color": "#F4A623", "value": 85 },
              { "color": "#2FD06A", "value": 95 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT ROUND(CAST(SUM(CASE WHEN OK_NOK = 'OK' THEN 1 ELSE 0 END) AS FLOAT) / COUNT(*) * 100, 1) AS value FROM LOG_TABLA WHERE fecha_creacion >= DATEADD(day, -30, GETUTCDATE())",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TIEMPOS DE ELEVACIÓN Y DESCENSO CON CARGA (Segundos)",
      "gridPos": { "x": 0, "y": 4, "w": 9, "h": 8 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [{
        "rawSql": "SELECT fecha_creacion AS time, TIEMPO_ELEVACION_MEDIDO_CARGA AS [Elevación con Carga], TIEMPO_DESCENSO_MEDIDO_CARGA AS [Descenso con Carga] FROM LOG_TABLA WHERE fecha_creacion >= $__timeFrom() AND fecha_creacion <= $__timeTo() AND TIEMPO_ELEVACION_MEDIDO_CARGA IS NOT NULL ORDER BY fecha_creacion",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TIEMPOS DE ELEVACIÓN Y DESCENSO SIN CARGA (Segundos)",
      "gridPos": { "x": 9, "y": 4, "w": 9, "h": 8 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [{
        "rawSql": "SELECT fecha_creacion AS time, TIEMPO_ELEVACION_MEDIDO_SINCARGA AS [Elevación sin Carga], TIEMPO_DESCENSO_MEDIDO_SINCARGA AS [Descenso sin Carga] FROM LOG_TABLA WHERE fecha_creacion >= $__timeFrom() AND fecha_creacion <= $__timeTo() AND TIEMPO_ELEVACION_MEDIDO_SINCARGA IS NOT NULL ORDER BY fecha_creacion",
        "format": "time_series",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "PRUEBAS POR MODELO DE MÁSTIL / MÁQUINA",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "orientation": "horizontal",
        "xField": "Modelo",
        "legend": { "displayMode": "hidden" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#25C9D6", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT NMODELO AS [Modelo], COUNT(*) AS [Pruebas] FROM LOG_TABLA WHERE fecha_creacion >= $__timeFrom() AND fecha_creacion <= $__timeTo() GROUP BY NMODELO ORDER BY COUNT(*) DESC",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "PRUEBAS POR OPERARIO (Rendimiento del Operador)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "orientation": "horizontal",
        "xField": "Operario",
        "legend": { "displayMode": "hidden" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#F4A623", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT OPERARIO AS [Operario], COUNT(*) AS [Pruebas] FROM LOG_TABLA WHERE fecha_creacion >= $__timeFrom() AND fecha_creacion <= $__timeTo() GROUP BY OPERARIO ORDER BY COUNT(*) DESC",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "id": 9,
      "type": "table",
      "title": "REGISTRO DETALLADO DE PRUEBAS (Historial Completo)",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 12 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "footer": { "show": true, "enablePagination": true, "fields": ["Resultado"] },
        "sortBy": [{ "displayName": "Fecha Creación", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Resultado" },
            "properties": [{
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "OK":  { "text": "OK",  "color": "#2FD06A" } } },
                { "type": "value", "options": { "NOK": { "text": "NOK", "color": "#E32636" } } }
              ]
            }]
          }
        ]
      },
      "targets": [{
        "rawSql": "SELECT fecha_creacion AS [Fecha Creación], OPERARIO AS [Operario], NBASTIDOR AS [Bastidor], NMODELO AS [Modelo], NMASTIL AS [Mástil], PESO_PRUEBA AS [Peso (kg)], CARGA_GET AS [Carga Medida], TIEMPO_ELEVACION_MEDIDO_CARGA AS [Elev Carga (s)], TIEMPO_DESCENSO_MEDIDO_CARGA AS [Desc Carga (s)], TIEMPO_ELEVACION_MEDIDO_SINCARGA AS [Elev Sin Carga (s)], DURACION_SEC AS [Duración], OK_NOK AS [Resultado] FROM LOG_TABLA WHERE fecha_creacion >= $__timeFrom() AND fecha_creacion <= $__timeTo() ORDER BY fecha_creacion DESC",
        "format": "table",
        "refId": "A"
      }]
    }
  ]
}
