    {
      "id": 1,
      "type": "stat",
      "title": "PRUEBAS TOTALES (Últimos 30 días)",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "datasource": { "uid": "mes_sqlserver" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "value"
